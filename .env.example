PORT=3006
NODE_ENV=development

# SMTP2GO — email delivery
SMTP2GO_API_KEY=your_key_here
SMTP2GO_FROM_EMAIL=noreply@zingmigration.com
SMTP2GO_FROM_NAME=ZING Website Forms

# Admin API key (for legacy /admin/sites endpoints)
ADMIN_KEY=your_admin_key_here

# Pixel Supabase — auto-lookup of owner_email for any imported site
# Set these and no manual site registration is needed
PIXEL_SUPABASE_URL=https://ohieyclfacdznghbyrpi.supabase.co
PIXEL_SUPABASE_SERVICE_KEY=your_pixel_service_role_key_here
